import java.util.Scanner;

class Harshad
{
    public static void main(String args[])
    {
        Scanner sc=new Scanner(System.in);

        System.out.print("Enter a number: ");
        int n=sc.nextInt();

        int t=n,sum=0,r;

        while(n>0)
        {
            r=n%10;
            sum=sum+r;
            n=n/10;
        }

        if(t%sum==0)
            System.out.println("Harshad Number");
        else
            System.out.println("Not Harshad Number");
    }
}
