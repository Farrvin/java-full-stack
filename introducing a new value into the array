//friends name list

import java.util.Arrays;

class Main {
    public static void main(String args[]) {
        
        String[] original = {"Thanuja", "Srinidhi", "Hasini", "Lalabi", "Mastanvali"};
        
        String newValue = "Subhanu";
        
        String[] newArray = Arrays.copyOf(original, original.length + 1);
        
        newArray[newArray.length - 1] = newValue;
        
        System.out.println("Element at index 3: " + newArray[3]);
        
        System.out.println("All friends:");
        for (int i = 0; i < newArray.length; i++) {
            System.out.println(newArray[i]);
        }
    }
}


//numbers
import java.util.Arrays;

class Main {
    public static void main(String args[]) {
        
        int[] original = {1, 2, 3};
        
        int newValue = 4;
        
        int[] newArray = Arrays.copyOf(original, original.length + 1);
        
        newArray[newArray.length - 1] = newValue;
        
        System.out.println("All elements:");
        for (int i = 0; i < newArray.length; i++) {
            System.out.println(newArray[i]);
        }
    }
}
