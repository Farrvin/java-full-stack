import java.util.Scanner;

class Spy
{
    public static void main(String args[])
    {
        Scanner sc=new Scanner(System.in);

        System.out.print("Enter a number: ");
        int n=sc.nextInt();

        int sum=0,pro=1,r;

        while(n>0)
        {
            r=n%10;
            sum=sum+r;
            pro=pro*r;
            n=n/10;
        }

        if(sum==pro)
            System.out.println("Spy Number");
        else
            System.out.println("Not Spy Number");
    }
}
